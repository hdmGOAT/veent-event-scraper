# ── Django ────────────────────────────────────────────────────────────────────
# Generate a fresh value: python -c "import secrets; print(secrets.token_urlsafe(50))"
# The key previously committed to git is BURNED — never reuse it. With DEBUG=false
# Django refuses to start unless SECRET_KEY is set.
SECRET_KEY=change-me-in-production
DEBUG=true
# Comma-separated hostnames Django will serve (production only). When unset in dev,
# Django falls back to localhost/127.0.0.1/testserver.
ALLOWED_HOSTS=your-domain.com
# Public origin added to CSRF_TRUSTED_ORIGINS in production (scheme + host).
PROD_ORIGIN=https://your-domain.com
DATABASE_URL=postgres://user:password@localhost:5432/veent_scraper

# ── Auth / session ────────────────────────────────────────────────────────────
# Per-user Django session auth. Tunables below are optional — defaults shown.
# Axes brute-force lockout: lock after N failed attempts per username+IP.
# AXES_FAILURE_LIMIT=5
# Cooloff window before a locked username+IP can retry (hours).
# AXES_COOLOFF_HOURS=1
# Session lifetime in seconds (default 8 hours = 28800).
# SESSION_COOKIE_AGE_SECONDS=28800

# ── Groq (AI categorization + FB/IG post structuring) ─────────────────────────
# Free tier at https://console.groq.com — 14k requests/day
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_CATEGORIZE_MODEL=llama-3.1-8b-instant
# Optional: override request timeout in seconds (default: 90)
# GROQ_TIMEOUT=90

# ── CRM ingest ────────────────────────────────────────────────────────────────
CRM_INGEST_URL=https://your-crm.example.com/api/leads/ingest
CRM_INGEST_SECRET=your-ingest-secret

# ── Proxies ───────────────────────────────────────────────────────────────────
# DataImpulse residential proxy (required for FB/IG scrapers on a server).
# Free proxies are too unreliable for social platforms.
DATAIMPULSE_USER=your-username__cr.ph
DATAIMPULSE_PASS=your-password
# DATAIMPULSE_HOST=gw.dataimpulse.com   # default
# DATAIMPULSE_PORT=823                  # default

# Set to false to disable proxies entirely (dev/local only — do not use in prod)
# SCRAPER_USE_PROXY=true

# ── Facebook scraper ──────────────────────────────────────────────────────────
# Path to exported Facebook session cookies (JSON format via "Cookie Editor" ext).
# Export: Chrome → Cookie Editor → Export All → JSON → save file → set path here.
# Cookies expire every ~60 days and must be refreshed manually.
FB_COOKIES_FILE=/path/to/www.facebook.com_cookies.json
# Optional: persistent browser profile dir (keeps login session across runs)
# FB_PROFILE_DIR=/path/to/fb-profile
# Set to false to watch the browser (dev only)
# FB_HEADLESS=true

# ── Instagram scraper ─────────────────────────────────────────────────────────
# Same cookie export process as Facebook.
IG_COOKIES_FILE=/path/to/www.instagram.com_cookies.txt
# IG_HEADLESS=true

# ── Discord notifications ─────────────────────────────────────────────────────
# Optional. When set, the scraper posts webhook embeds to this channel on
# job start / scraper success / scraper failure / session expiry.
# Omit or leave blank to disable all Discord notifications silently.
# Create a webhook: Discord channel settings → Integrations → Webhooks → New Webhook
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# ── External APIs ─────────────────────────────────────────────────────────────
# Google Places API (venue enrichment)
PLACES_API_KEY=your-google-places-key

# AllEvents API (free tier at https://allevents.developer.azure-api.net)
ALLEVENTS_API_KEY=your-allevents-key
