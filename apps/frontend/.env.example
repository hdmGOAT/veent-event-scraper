# SvelteKit runtime env vars (read at process start, not build time).
# Copy to apps/frontend/.env for local overrides, or set these in the PM2 /
# systemd unit in production.

# Upstream API targets proxied by src/hooks.server.ts.
DJANGO_API_URL=http://localhost:8000
NODE_API_URL=http://localhost:8001

# "production" enables per-user auth (validates against Django session). Any other value runs in dev mode with no auth gate.
ENVIRONMENT=development
