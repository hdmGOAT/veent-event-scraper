# ══════════════════════════════════════════════════════════════════════════════
# Veent Event Scraper — Docker Compose environment
# Copy to .env (`cp .env.example .env`) and fill in every value, then:
#   docker compose up -d --build
# .env is git-ignored — never commit real secrets.
# ══════════════════════════════════════════════════════════════════════════════

# ── Deployment / TLS ──────────────────────────────────────────────────────────
# Public domain Caddy serves and obtains a Let's Encrypt cert for. Use `localhost`
# for a local run (Caddy serves a self-signed cert). Must resolve to this host and
# have ports 80/443 reachable for real certificates.
DOMAIN=your-domain.com

# ── Django ────────────────────────────────────────────────────────────────────
# Generate a fresh value — the key previously in git history is BURNED:
#   python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=change-me-in-production
# Keep false in production (enables SSL redirect, HSTS, secure cookies, Axes).
DEBUG=false
# Comma-separated public hostnames. `backend` is appended automatically by
# docker-compose for internal service-to-service calls — do not add it here.
ALLOWED_HOSTS=your-domain.com
# Public origin (scheme + host) added to CSRF_TRUSTED_ORIGINS.
PROD_ORIGIN=https://your-domain.com
# External managed Postgres (Neon). SSL is required when DEBUG=false.
DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

# ── Frontend (SvelteKit) ──────────────────────────────────────────────────────
# `production` enables the per-user auth gate; any other value = dev (no gate).
# DJANGO_API_URL is set by docker-compose to the internal backend service.
ENVIRONMENT=production

# ── Auth / session (optional — defaults shown) ────────────────────────────────
# AXES_FAILURE_LIMIT=5
# AXES_COOLOFF_HOURS=1
# SESSION_COOKIE_AGE_SECONDS=28800

# ── Groq (AI categorization + FB/IG post structuring) ─────────────────────────
# Free tier at https://console.groq.com
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_CATEGORIZE_MODEL=llama-3.1-8b-instant
# GROQ_TIMEOUT=90

# ── CRM ingest ────────────────────────────────────────────────────────────────
CRM_INGEST_URL=https://your-crm.example.com/api/leads/ingest
CRM_INGEST_SECRET=your-ingest-secret

# ── Proxies (DataImpulse residential — required for FB/IG on a server) ─────────
DATAIMPULSE_USER=your-username__cr.ph
DATAIMPULSE_PASS=your-password
# DATAIMPULSE_HOST=gw.dataimpulse.com   # default
# DATAIMPULSE_PORT=823                  # default
# SCRAPER_USE_PROXY=true                # set false to disable proxies (dev only)

# ── Facebook / Instagram scrapers ─────────────────────────────────────────────
# Put your exported cookie files in ./cookies/ on the host — it is mounted
# read-only into the backend container at /cookies. See docs/deployment §9.
FB_COOKIES_FILE=/cookies/facebook.json
# FB_HEADLESS=true
IG_COOKIES_FILE=/cookies/instagram.txt
# IG_HEADLESS=true

# ── Discord notifications (optional) ──────────────────────────────────────────
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# ── External APIs ─────────────────────────────────────────────────────────────
PLACES_API_KEY=your-google-places-key
ALLEVENTS_API_KEY=your-allevents-key
